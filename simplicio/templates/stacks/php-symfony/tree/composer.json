{
  "name": "simplicio/{project_name}",
  "description": "{goal}",
  "type": "project",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "symfony/framework-bundle": "^7.0",
    "symfony/runtime": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11"
  }
}
