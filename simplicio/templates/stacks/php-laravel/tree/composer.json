{
  "name": "simplicio/{project_name}",
  "type": "project",
  "description": "Simplicio Laravel scratch project.",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php artisan test"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
